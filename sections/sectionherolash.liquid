{% comment %}
  ============================================================
  SECTION : Hero (blob dégradé + capsule + badges)
  ------------------------------------------------------------
  Installation :
  1. Shopify admin → Boutique en ligne → Thèmes → ⋯ → Modifier le code
  2. Dossier "Sections" → "Ajouter une nouvelle section"
  3. Nommer : hero-pack → coller tout ce fichier → Enregistrer
  4. Éditeur de thème → "Ajouter une section" → "Hero — Pack beauté"
  ------------------------------------------------------------
  Astuces pour le titre :
  - Entourez un mot de *astérisques* → italique élégant.
  - Écrivez [capsule] à l'endroit où placer la petite capsule
    dégradée. Ex : Du contenu qui [capsule] *attire des clientes,*
  - Un retour à la ligne crée un saut de ligne.
  Les badges (Prothésistes ongulaires…) sont des blocs :
  ajoutez-en, supprimez, réordonnez librement.
  ============================================================
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign use_fonts = section.settings.use_custom_fonts
  assign ms = section.settings.mobile_scale | divided_by: 100.0
-%}

{%- if use_fonts -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@400;500;600;700&family=Playfair+Display:ital,wght@1,500&display=swap" rel="stylesheet">
{%- endif -%}

<style>
  #hero-{{ sid }}{
    --hr-bg: {{ section.settings.page_bg }};
    --hr-ink: {{ section.settings.text_color }};
    --hr-italic: {{ section.settings.italic_color }};
    --hr-muted: {{ section.settings.muted_color }};
    --hr-tag-bg: {{ section.settings.tag_bg }};
    --hr-tag-line: {{ section.settings.tag_border }};
    --hr-tag-txt: {{ section.settings.tag_text }};
    --hr-btn-bg: {{ section.settings.btn_bg }};
    --hr-btn-hover: {{ section.settings.btn_hover_bg }};
    --hr-btn-txt: {{ section.settings.btn_text_color }};
    background:var(--hr-bg);
    position:relative;overflow:hidden;text-align:center;
    padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    {%- if use_fonts -%}
    font-family:'Host Grotesk',sans-serif;
    {%- endif -%}
    color:var(--hr-ink);
    line-height:1.7;
  }
  #hero-{{ sid }} *{margin:0;padding:0;box-sizing:border-box}
  #hero-{{ sid }} .hr-wrap{max-width:1200px;margin:0 auto;padding:0 28px;position:relative;z-index:1}

  /* ---- Blob ---- */
  {%- if section.settings.show_blob -%}
  #hero-{{ sid }} .hr-blob{
    position:absolute;left:50%;top:44%;transform:translate(-50%,-50%);
    width:760px;height:520px;pointer-events:none;
    filter:blur(60px);
    opacity:{{ section.settings.blob_opacity | divided_by: 100.0 }};
    background:
      radial-gradient(220px 180px at 32% 40%, {{ section.settings.blob_color_1 }} 0%, transparent 70%),
      radial-gradient(240px 200px at 68% 32%, {{ section.settings.blob_color_2 }} 0%, transparent 70%),
      radial-gradient(230px 200px at 55% 70%, {{ section.settings.blob_color_3 }} 0%, transparent 70%);
    {%- if section.settings.blob_animate -%}
    animation:hr-drift-{{ sid }} 14s ease-in-out infinite alternate;
    {%- endif -%}
  }
  @keyframes hr-drift-{{ sid }}{
    from{transform:translate(-50%,-50%) rotate(-3deg) scale(1)}
    to{transform:translate(-50%,-50%) rotate(4deg) scale(1.07)}
  }
  @media (prefers-reduced-motion:reduce){
    #hero-{{ sid }} .hr-blob{animation:none}
  }
  {%- endif -%}


  /* ---- Éventail de cartes ---- */
  {%- if section.settings.show_fan -%}
  #hero-{{ sid }} .hr-fan{
    position:relative;z-index:1;
    height:{{ section.settings.fan_height }}px;
    max-width:640px;margin:0 auto 34px;
  }
  #hero-{{ sid }} .hr-card{
    position:absolute;left:50%;top:50%;
    width:{{ section.settings.card_w }}px;height:{{ section.settings.card_h }}px;
    border-radius:18px;overflow:hidden;
    background:#fff;
    {%- if section.settings.show_card_shadow -%}
    box-shadow:0 18px 50px -18px rgba(34,24,32,.25);
    {%- endif -%}
    transform-origin:50% 120%;
    transition:transform .5s cubic-bezier(.22,1,.36,1);
    display:flex;flex-direction:column;
  }
  #hero-{{ sid }} .hr-card[data-pos="1"]{transform:translate(-50%,-50%) rotate(-14deg) translateX(-84px);z-index:1}
  #hero-{{ sid }} .hr-card[data-pos="2"]{transform:translate(-50%,-50%) rotate(-2deg) translateY(-8px);z-index:2}
  #hero-{{ sid }} .hr-card[data-pos="3"]{transform:translate(-50%,-50%) rotate(10deg) translateX(88px);z-index:1}
  #hero-{{ sid }} .hr-fan:hover .hr-card[data-pos="1"]{transform:translate(-50%,-50%) rotate(-18deg) translateX(-104px)}
  #hero-{{ sid }} .hr-fan:hover .hr-card[data-pos="2"]{transform:translate(-50%,-50%) rotate(0deg) translateY(-20px)}
  #hero-{{ sid }} .hr-fan:hover .hr-card[data-pos="3"]{transform:translate(-50%,-50%) rotate(14deg) translateX(108px)}
  #hero-{{ sid }} .hr-card .c-bar{
    flex-shrink:0;height:34px;display:flex;align-items:center;gap:6px;padding:0 12px;
    background:rgba(255,255,255,.6);border-bottom:1px solid rgba(0,0,0,.05);
  }
  #hero-{{ sid }} .hr-card .c-bar .av{width:16px;height:16px;border-radius:50%;background:{{ section.settings.card_chrome_color }}}
  #hero-{{ sid }} .hr-card .c-bar .nm{height:7px;width:70px;border-radius:4px;background:rgba(0,0,0,.08)}
  #hero-{{ sid }} .hr-card .c-body{
    flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
    gap:10px;padding:16px;text-align:center;position:relative;overflow:hidden;
  }
  #hero-{{ sid }} .hr-card .c-body img{
    position:absolute;inset:0;width:100%;height:100%;object-fit:cover;
  }
  #hero-{{ sid }} .hr-card .c-tag{
    font-size:{{ section.settings.size_card_tag }}px;
    font-weight:600;letter-spacing:.16em;text-transform:uppercase;
  }
  #hero-{{ sid }} .hr-card .c-ttl{
    {%- if use_fonts -%}
    font-family:'Playfair Display',serif;
    {%- endif -%}
    font-style:italic;font-weight:500;
    font-size:{{ section.settings.size_card_title }}px;
    line-height:1.35;color:var(--hr-ink);
  }
  #hero-{{ sid }} .hr-card .c-foot{flex-shrink:0;display:flex;gap:8px;padding:12px 14px;background:rgba(255,255,255,.6)}
  #hero-{{ sid }} .hr-card .c-foot i{width:14px;height:14px;border-radius:50%;background:rgba(0,0,0,.08);display:block}

  /* Badges flottants */
  #hero-{{ sid }} .hr-float{
    position:absolute;z-index:3;
    background:#fff;border-radius:999px;
    padding:10px 18px;font-weight:600;
    font-size:{{ section.settings.size_float }}px;
    {%- if section.settings.show_card_shadow -%}
    box-shadow:0 18px 50px -22px rgba(34,24,32,.3);
    {%- endif -%}
    display:flex;align-items:center;gap:8px;white-space:nowrap;
  }
  #hero-{{ sid }} .hr-float.f1{top:0;left:0}
  #hero-{{ sid }} .hr-float.f2{bottom:0;right:0}
  #hero-{{ sid }} .hr-float .dot{width:9px;height:9px;border-radius:50%;background:{{ section.settings.card_chrome_color }}}
  {%- endif -%}

  /* ---- Eyebrow ---- */
  #hero-{{ sid }} .hr-eyebrow{
    display:flex;align-items:center;justify-content:center;gap:14px;
    font-size:{{ section.settings.size_eyebrow }}px;
    font-weight:500;letter-spacing:.22em;text-transform:uppercase;
    color:var(--hr-muted);margin-bottom:22px;
  }
  #hero-{{ sid }} .hr-eyebrow .sep{height:1px;width:36px;background:var(--hr-muted);opacity:.4}
  #hero-{{ sid }} .hr-eyebrow .n{color:var(--hr-ink)}

  /* ---- Titre ---- */
  #hero-{{ sid }} .hr-title{
    font-weight:{{ section.settings.weight_title }};
    font-size:{{ section.settings.size_title }}px;
    line-height:1.12;letter-spacing:-.03em;
    max-width:19em;margin:0 auto 30px;
  }
  #hero-{{ sid }} .hr-title em{
    {%- if use_fonts -%}
    font-family:'Playfair Display',serif;
    {%- endif -%}
    font-style:italic;font-weight:500;letter-spacing:0;
    font-size:1.05em;color:var(--hr-italic);
  }
  #hero-{{ sid }} .hr-chip{
    display:inline-block;vertical-align:middle;
    width:1.85em;height:.95em;border-radius:999px;
    background:linear-gradient(120deg,{{ section.settings.chip_color_1 }} 0%,{{ section.settings.chip_color_2 }} 40%,{{ section.settings.chip_color_3 }} 100%);
    position:relative;overflow:hidden;margin:0 .08em;
    box-shadow:inset 0 2px 6px rgba(255,255,255,.5), 0 8px 20px -6px rgba(201,69,119,.5);
  }
  #hero-{{ sid }} .hr-chip::after{
    content:"";position:absolute;inset:0;
    background:repeating-linear-gradient(115deg,transparent 0 8px,rgba(255,255,255,.35) 8px 12px);
  }

  /* ---- Sous-titre ---- */
  #hero-{{ sid }} .hr-sub{
    color:var(--hr-muted);
    font-size:{{ section.settings.size_sub }}px;
    max-width:36em;margin:0 auto 40px;
  }

  /* ---- Badges ---- */
  #hero-{{ sid }} .hr-tags{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:42px}
  #hero-{{ sid }} .hr-tags span{
    background:var(--hr-tag-bg);border:1px solid var(--hr-tag-line);border-radius:999px;
    padding:8px 18px;
    font-size:{{ section.settings.size_tag }}px;
    font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--hr-tag-txt);
  }

  /* ---- CTA ---- */
  #hero-{{ sid }} .hr-cta{display:flex;justify-content:center;align-items:center;gap:22px;flex-wrap:wrap}
  #hero-{{ sid }} .hr-btn{
    display:inline-flex;align-items:center;gap:12px;
    background:var(--hr-btn-bg);color:var(--hr-btn-txt);
    font-size:{{ section.settings.size_btn }}px;
    font-weight:500;letter-spacing:.14em;text-transform:uppercase;
    padding:14px 8px 14px 26px;border-radius:999px;text-decoration:none;
    transition:background .25s ease,transform .25s ease;
  }
  #hero-{{ sid }} .hr-btn .arr{
    width:32px;height:32px;border-radius:50%;
    background:var(--hr-btn-txt);color:var(--hr-btn-bg);
    display:flex;align-items:center;justify-content:center;
    font-size:.9rem;transition:transform .25s ease;
  }
  #hero-{{ sid }} .hr-btn:hover{background:var(--hr-btn-hover);transform:translateY(-2px)}
  #hero-{{ sid }} .hr-btn:hover .arr{transform:rotate(45deg)}
  #hero-{{ sid }} .hr-note{
    font-size:{{ section.settings.size_note }}px;
    color:var(--hr-muted);
  }
  #hero-{{ sid }} .hr-note b{color:var(--hr-ink);font-weight:600}

  /* ---- Responsive ---- */
  @media (max-width:640px){
    #hero-{{ sid }}{padding:calc({{ section.settings.padding_top }}px * .65) 0 calc({{ section.settings.padding_bottom }}px * .65)}
    {%- if section.settings.show_fan -%}
    #hero-{{ sid }} .hr-fan{height:calc({{ section.settings.fan_height }}px * .72);margin-bottom:26px}
    #hero-{{ sid }} .hr-card{width:calc({{ section.settings.card_w }}px * .72);height:calc({{ section.settings.card_h }}px * .72)}
    #hero-{{ sid }} .hr-card[data-pos="1"]{transform:translate(-50%,-50%) rotate(-14deg) translateX(-58px)}
    #hero-{{ sid }} .hr-card[data-pos="3"]{transform:translate(-50%,-50%) rotate(10deg) translateX(60px)}
    #hero-{{ sid }} .hr-card .c-tag{font-size:calc({{ section.settings.size_card_tag }}px * {{ ms }})}
    #hero-{{ sid }} .hr-card .c-ttl{font-size:calc({{ section.settings.size_card_title }}px * {{ ms }})}
    #hero-{{ sid }} .hr-float{font-size:calc({{ section.settings.size_float }}px * {{ ms }});padding:8px 14px}
    {%- endif -%}
    #hero-{{ sid }} .hr-wrap{padding:0 18px}
    #hero-{{ sid }} .hr-blob{width:480px;height:400px}
    #hero-{{ sid }} .hr-eyebrow{font-size:calc({{ section.settings.size_eyebrow }}px * {{ ms }});gap:10px}
    #hero-{{ sid }} .hr-eyebrow .sep{width:22px}
    #hero-{{ sid }} .hr-title{font-size:calc({{ section.settings.size_title }}px * {{ ms }})}
    #hero-{{ sid }} .hr-sub{font-size:calc({{ section.settings.size_sub }}px * {{ ms }});margin-bottom:30px}
    #hero-{{ sid }} .hr-tags{gap:8px;margin-bottom:32px}
    #hero-{{ sid }} .hr-tags span{font-size:calc({{ section.settings.size_tag }}px * {{ ms }});padding:7px 14px}
    #hero-{{ sid }} .hr-btn{font-size:calc({{ section.settings.size_btn }}px * {{ ms }})}
    #hero-{{ sid }} .hr-note{font-size:calc({{ section.settings.size_note }}px * {{ ms }})}
  }
</style>

{%- capture chip_html -%}<span class="hr-chip" aria-hidden="true"></span>{%- endcapture -%}

<div id="hero-{{ sid }}">
  {%- if section.settings.show_blob -%}
  <div class="hr-blob" aria-hidden="true"></div>
  {%- endif -%}
  <div class="hr-wrap">

    {%- if section.settings.show_fan -%}
    {%- assign cartes = section.blocks | where: "type", "carte" -%}
    {%- if cartes.size > 0 -%}
    <div class="hr-fan">
      {%- if section.settings.float_left != blank -%}
      <div class="hr-float f1"><span class="dot"></span>{{ section.settings.float_left }}</div>
      {%- endif -%}
      {%- for block in cartes limit: 3 -%}
      <div class="hr-card" data-pos="{{ forloop.index }}" style="background:linear-gradient(160deg,{{ block.settings.grad_1 }},{{ block.settings.grad_2 }})" {{ block.shopify_attributes }}>
        <div class="c-bar"><span class="av"></span><span class="nm"></span></div>
        <div class="c-body">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | default: 'Aperçu de post Instagram' | escape }}" loading="lazy" width="600" height="600">
          {%- else -%}
            {%- if block.settings.tag != blank -%}
            <span class="c-tag" style="color:{{ block.settings.tag_color }}">{{ block.settings.tag }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
            <span class="c-ttl">{{ block.settings.title }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>
        <div class="c-foot"><i></i><i></i><i></i></div>
      </div>
      {%- endfor -%}
      {%- if section.settings.float_right != blank -%}
      <div class="hr-float f2">{{ section.settings.float_right }}</div>
      {%- endif -%}
    </div>
    {%- endif -%}
    {%- endif -%}

    {%- if section.settings.eyebrow_number != blank or section.settings.eyebrow_text != blank -%}
    <div class="hr-eyebrow">
      {%- if section.settings.eyebrow_number != blank -%}<span class="n">{{ section.settings.eyebrow_number }}</span><span class="sep"></span>{%- endif -%}
      <span>{{ section.settings.eyebrow_text }}</span>
    </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
    <h1 class="hr-title">
      {%- assign lines = section.settings.heading | newline_to_br | split: '<br />' -%}
      {%- for line in lines -%}
        {%- assign parts = line | split: '*' -%}
        {%- for part in parts -%}
          {%- assign idx = forloop.index0 | modulo: 2 -%}
          {%- assign rendered = part | replace: '[capsule]', chip_html -%}
          {%- if idx == 1 -%}<em>{{ rendered }}</em>{%- else -%}{{ rendered }}{%- endif -%}
        {%- endfor -%}
        {%- unless forloop.last -%}<br>{%- endunless -%}
      {%- endfor -%}
    </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
    <p class="hr-sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- assign tags = section.blocks | where: "type", "tag" -%}
    {%- if tags.size > 0 -%}
    <div class="hr-tags">
      {%- for block in tags -%}
      <span {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <div class="hr-cta">
      {%- if section.settings.button_label != blank -%}
      <a class="hr-btn" href="{{ section.settings.button_link | default: '#' }}">
        {{ section.settings.button_label }}<span class="arr">&rarr;</span>
      </a>
      {%- endif -%}
      {%- if section.settings.note != blank -%}
      <span class="hr-note">
        {%- assign nparts = section.settings.note | split: '*' -%}
        {%- for part in nparts -%}
          {%- assign nidx = forloop.index0 | modulo: 2 -%}
          {%- if nidx == 1 -%}<b>{{ part }}</b>{%- else -%}{{ part }}{%- endif -%}
        {%- endfor -%}
      </span>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Hero — Pack beauté",
  "tag": "section",
  "class": "section-hero-pack",
  "settings": [
    { "type": "header", "content": "Sur-titre" },
    { "type": "text", "id": "eyebrow_number", "label": "Numéro (ex : 01)", "default": "01" },
    { "type": "text", "id": "eyebrow_text", "label": "Texte du sur-titre", "default": "Le pack réseaux sociaux beauté" },

    { "type": "header", "content": "Titre" },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre",
      "info": "*astérisques* = italique élégant · [capsule] = capsule dégradée · retour à la ligne = saut de ligne",
      "default": "Du contenu qui [capsule] *attire des clientes,*\nsans chercher quoi publier."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "150 templates et scripts prêts à personnaliser pour publier du contenu professionnel, mettre vos prestations en valeur et remplir votre agenda — sur Instagram et Facebook."
    },

    { "type": "header", "content": "Bouton et note" },
    { "type": "text", "id": "button_label", "label": "Texte du bouton", "default": "Je profite de l'offre" },
    { "type": "url", "id": "button_link", "label": "Lien du bouton" },
    {
      "type": "text",
      "id": "note",
      "label": "Note à côté du bouton",
      "info": "*astérisques* = texte en gras. Ex : *39 €* au lieu de 59 €",
      "default": "*39 €* au lieu de 59 € · Accès immédiat"
    },

    { "type": "header", "content": "Cartes au-dessus du titre" },
    { "type": "checkbox", "id": "show_fan", "label": "Afficher l'éventail de cartes", "default": true },
    { "type": "checkbox", "id": "show_card_shadow", "label": "Ombre des cartes", "default": true },
    { "type": "range", "id": "fan_height", "label": "Hauteur de la zone", "min": 260, "max": 560, "step": 10, "unit": "px", "default": 420 },
    { "type": "range", "id": "card_w", "label": "Largeur des cartes", "min": 150, "max": 300, "step": 5, "unit": "px", "default": 220 },
    { "type": "range", "id": "card_h", "label": "Hauteur des cartes", "min": 200, "max": 400, "step": 5, "unit": "px", "default": 290 },
    { "type": "color", "id": "card_chrome_color", "label": "Pastille avatar / point des badges", "default": "#C94577" },
    { "type": "text", "id": "float_left", "label": "Badge flottant gauche", "default": "150 contenus prêts à publier" },
    { "type": "text", "id": "float_right", "label": "Badge flottant droit", "default": "🎁 2 e-books offerts" },

    { "type": "header", "content": "Typographie (tailles en px)" },
    { "type": "range", "id": "size_title", "label": "Titre", "min": 26, "max": 84, "step": 1, "unit": "px", "default": 58 },
    { "type": "select", "id": "weight_title", "label": "Graisse du titre", "default": "600", "options": [
      { "value": "400", "label": "Normale (400)" },
      { "value": "500", "label": "Moyenne (500)" },
      { "value": "600", "label": "Semi-gras (600)" },
      { "value": "700", "label": "Gras (700)" }
    ] },
    { "type": "range", "id": "size_eyebrow", "label": "Sur-titre", "min": 8, "max": 18, "step": 1, "unit": "px", "default": 11 },
    { "type": "range", "id": "size_sub", "label": "Sous-titre", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "size_tag", "label": "Badges", "min": 8, "max": 16, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "size_btn", "label": "Texte du bouton", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "size_note", "label": "Note à côté du bouton", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "size_card_tag", "label": "Sur-titre des cartes", "min": 7, "max": 14, "step": 1, "unit": "px", "default": 9 },
    { "type": "range", "id": "size_card_title", "label": "Titre des cartes", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "size_float", "label": "Badges flottants", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "mobile_scale", "label": "Échelle des textes sur mobile", "min": 55, "max": 100, "step": 5, "unit": "%", "default": 70 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "page_bg", "label": "Fond de la section", "default": "#F3EEEF" },
    { "type": "color", "id": "text_color", "label": "Titre", "default": "#221820" },
    { "type": "color", "id": "italic_color", "label": "Mots en italique", "default": "#221820" },
    { "type": "color", "id": "muted_color", "label": "Sous-titre et note", "default": "#6F6068" },
    { "type": "color", "id": "tag_bg", "label": "Fond des badges", "default": "#FFFFFF" },
    { "type": "color", "id": "tag_border", "label": "Bordure des badges", "default": "#E7DDE1" },
    { "type": "color", "id": "tag_text", "label": "Texte des badges", "default": "#6F6068" },
    { "type": "color", "id": "btn_bg", "label": "Fond du bouton", "default": "#C94577" },
