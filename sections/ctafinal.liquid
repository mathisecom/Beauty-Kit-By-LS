{% comment %}
  ============================================================
  SECTION : Appel à l'action final (blob dégradé)
  ------------------------------------------------------------
  Installation :
  1. Shopify admin → Boutique en ligne → Thèmes → ⋯ → Modifier le code
  2. Dossier "Sections" → "Ajouter une nouvelle section"
  3. Nommer : cta-final → coller tout ce fichier → Enregistrer
  4. Éditeur de thème → "Ajouter une section" → "Appel à l'action final"
  ------------------------------------------------------------
  Astuces :
  - Entourez un mot de *astérisques* pour le mettre en italique
    élégant. Ex : Votre prochain post est *déjà prêt.*
  - Un retour à la ligne dans le champ titre crée un saut de
    ligne sur la page.
  ============================================================
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign use_fonts = section.settings.use_custom_fonts
  assign ms = section.settings.mobile_scale | divided_by: 100.0
-%}

{%- if use_fonts -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@400;500;600;700&family=Playfair+Display:ital,wght@1,500&display=swap" rel="stylesheet">
{%- endif -%}

<style>
  #cta-{{ sid }}{
    --ct-bg: {{ section.settings.page_bg }};
    --ct-ink: {{ section.settings.text_color }};
    --ct-muted: {{ section.settings.muted_color }};
    --ct-italic: {{ section.settings.italic_color }};
    --ct-btn-bg: {{ section.settings.btn_bg }};
    --ct-btn-hover: {{ section.settings.btn_hover_bg }};
    --ct-btn-txt: {{ section.settings.btn_text_color }};
    background:var(--ct-bg);
    position:relative;overflow:hidden;
    padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    text-align:center;
    {%- if use_fonts -%}
    font-family:'Host Grotesk',sans-serif;
    {%- endif -%}
    color:var(--ct-ink);
    line-height:1.7;
  }
  #cta-{{ sid }} *{margin:0;padding:0;box-sizing:border-box}
  #cta-{{ sid }} .ct-wrap{max-width:1200px;margin:0 auto;padding:0 28px;position:relative;z-index:1}

  /* ---- Blob dégradé ---- */
  {%- if section.settings.show_blob -%}
  #cta-{{ sid }} .ct-blob{
    position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
    width:760px;height:520px;pointer-events:none;
    filter:blur(60px);
    opacity:{{ section.settings.blob_opacity | divided_by: 100.0 }};
    background:
      radial-gradient(220px 180px at 32% 40%, {{ section.settings.blob_color_1 }} 0%, transparent 70%),
      radial-gradient(240px 200px at 68% 32%, {{ section.settings.blob_color_2 }} 0%, transparent 70%),
      radial-gradient(230px 200px at 55% 70%, {{ section.settings.blob_color_3 }} 0%, transparent 70%);
    {%- if section.settings.blob_animate -%}
    animation:ct-drift-{{ sid }} 14s ease-in-out infinite alternate;
    {%- endif -%}
  }
  @keyframes ct-drift-{{ sid }}{
    from{transform:translate(-50%,-50%) rotate(-3deg) scale(1)}
    to{transform:translate(-50%,-50%) rotate(4deg) scale(1.07)}
  }
  @media (prefers-reduced-motion:reduce){
    #cta-{{ sid }} .ct-blob{animation:none}
  }
  {%- endif -%}

  /* ---- Titre ---- */
  #cta-{{ sid }} .ct-title{
    font-weight:{{ section.settings.weight_title }};
    font-size:{{ section.settings.size_title }}px;
    line-height:1.2;letter-spacing:-.03em;
    max-width:17em;margin:0 auto 22px;
  }
  #cta-{{ sid }} .ct-title em{
    {%- if use_fonts -%}
    font-family:'Playfair Display',serif;
    {%- endif -%}
    font-style:italic;font-weight:500;letter-spacing:0;
    color:var(--ct-italic);
  }

  /* ---- Sous-titre ---- */
  #cta-{{ sid }} .ct-sub{
    color:var(--ct-muted);
    font-size:{{ section.settings.size_sub }}px;
    max-width:33em;margin:0 auto {{ section.settings.gap_sub_btn }}px;
  }

  /* ---- Bouton ---- */
  #cta-{{ sid }} .ct-btn{
    display:inline-flex;align-items:center;gap:12px;
    background:var(--ct-btn-bg);color:var(--ct-btn-txt);
    font-size:{{ section.settings.size_btn }}px;
    font-weight:500;letter-spacing:.14em;text-transform:uppercase;
    padding:{{ section.settings.btn_padding_v }}px 8px {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    border-radius:999px;text-decoration:none;
    transition:background .25s ease,transform .25s ease;
  }
  #cta-{{ sid }} .ct-btn .arr{
    width:32px;height:32px;border-radius:50%;
    background:var(--ct-btn-txt);color:var(--ct-btn-bg);
    display:flex;align-items:center;justify-content:center;
    font-size:.9rem;transition:transform .25s ease;
  }
  #cta-{{ sid }} .ct-btn:hover{background:var(--ct-btn-hover);transform:translateY(-2px)}
  #cta-{{ sid }} .ct-btn:hover .arr{transform:rotate(45deg)}
  #cta-{{ sid }} .ct-note{
    display:block;margin-top:14px;
    font-size:{{ section.settings.size_note }}px;
    color:var(--ct-muted);
  }

  /* ---- Responsive ---- */
  @media (max-width:640px){
    #cta-{{ sid }}{padding:calc({{ section.settings.padding_top }}px * .7) 0 calc({{ section.settings.padding_bottom }}px * .7)}
    #cta-{{ sid }} .ct-wrap{padding:0 18px}
    #cta-{{ sid }} .ct-blob{width:480px;height:380px}
    #cta-{{ sid }} .ct-title{font-size:calc({{ section.settings.size_title }}px * {{ ms }})}
    #cta-{{ sid }} .ct-sub{font-size:calc({{ section.settings.size_sub }}px * {{ ms }});margin-bottom:calc({{ section.settings.gap_sub_btn }}px * .8)}
    #cta-{{ sid }} .ct-btn{font-size:calc({{ section.settings.size_btn }}px * {{ ms }})}
    #cta-{{ sid }} .ct-note{font-size:calc({{ section.settings.size_note }}px * {{ ms }})}
  }
</style>

<div id="cta-{{ sid }}">
  {%- if section.settings.show_blob -%}
  <div class="ct-blob" aria-hidden="true"></div>
  {%- endif -%}
  <div class="ct-wrap">

    {%- if section.settings.heading != blank -%}
    <h2 class="ct-title">
      {%- assign lines = section.settings.heading | newline_to_br | split: '<br />' -%}
      {%- for line in lines -%}
        {%- assign parts = line | split: '*' -%}
        {%- for part in parts -%}
          {%- assign idx = forloop.index0 | modulo: 2 -%}
          {%- if idx == 1 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
        {%- endfor -%}
        {%- unless forloop.last -%}<br>{%- endunless -%}
      {%- endfor -%}
    </h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
    <p class="ct-sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
    <a class="ct-btn" href="{{ section.settings.button_link | default: '#' }}">
      {{ section.settings.button_label }}<span class="arr">&rarr;</span>
    </a>
    {%- endif -%}

    {%- if section.settings.note != blank -%}
    <span class="ct-note">{{ section.settings.note }}</span>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Appel à l'action final",
  "tag": "section",
  "class": "section-cta-final",
  "settings": [
    { "type": "header", "content": "Textes" },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre",
      "info": "Entourez un mot de *astérisques* pour l'italique élégant. Un retour à la ligne crée un saut de ligne.",
      "default": "Votre prochain post est *déjà prêt.*\nIl ne manque que vous."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Rejoignez les professionnelles de la beauté qui publient du contenu qui attire — sans y passer leurs soirées."
    },
    { "type": "text", "id": "note", "label": "Petite note sous le bouton", "info": "Laisser vide pour ne rien afficher" },

    { "type": "header", "content": "Bouton" },
    { "type": "text", "id": "button_label", "label": "Texte du bouton", "default": "Obtenir le pack à 39 €" },
    { "type": "url", "id": "button_link", "label": "Lien du bouton" },

    { "type": "header", "content": "Typographie (tailles en px)" },
    { "type": "range", "id": "size_title", "label": "Titre", "min": 22, "max": 72, "step": 1, "unit": "px", "default": 48 },
    { "type": "select", "id": "weight_title", "label": "Graisse du titre", "default": "600", "options": [
      { "value": "400", "label": "Normale (400)" },
      { "value": "500", "label": "Moyenne (500)" },
      { "value": "600", "label": "Semi-gras (600)" },
      { "value": "700", "label": "Gras (700)" }
    ] },
    { "type": "range", "id": "size_sub", "label": "Sous-titre", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "size_btn", "label": "Texte du bouton", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "size_note", "label": "Petite note", "min": 9, "max": 16, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "mobile_scale", "label": "Échelle des textes sur mobile", "min": 60, "max": 100, "step": 5, "unit": "%", "default": 80 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "page_bg", "label": "Fond de la section", "default": "#F3EEEF" },
    { "type": "color", "id": "text_color", "label": "Titre", "default": "#221820" },
    { "type": "color", "id": "italic_color", "label": "Mots en italique", "default": "#221820" },
    { "type": "color", "id": "muted_color", "label": "Sous-titre et note", "default": "#6F6068" },
    { "type": "color", "id": "btn_bg", "label": "Fond du bouton", "default": "#C94577" },
    { "type": "color", "id": "btn_hover_bg", "label": "Fond du bouton au survol", "default": "#221820" },
    { "type": "color", "id": "btn_text_color", "label": "Texte du bouton", "default": "#FFFFFF" },

    { "type": "header", "content": "Blob dégradé" },
    { "type": "checkbox", "id": "show_blob", "label": "Afficher le dégradé flou", "default": true },
    { "type": "checkbox", "id": "blob_animate", "label": "Animer le dégradé", "default": true },
    { "type": "color", "id": "blob_color_1", "label": "Couleur 1", "default": "#F9C6D9" },
    { "type": "color", "id": "blob_color_2", "label": "Couleur 2", "default": "#F3D9B8" },
    { "type": "color", "id": "blob_color_3", "label": "Couleur 3", "default": "#E3C4F0" },
    { "type": "range", "id": "blob_opacity", "label": "Intensité du dégradé", "min": 10, "max": 100, "step": 5, "unit": "%", "default": 55 },

    { "type": "header", "content": "Mise en forme" },
    { "type": "range", "id": "gap_sub_btn", "label": "Espace sous-titre / bouton", "min": 16, "max": 80, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "btn_padding_v", "label": "Hauteur du bouton", "min": 8, "max": 24, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "btn_padding_h", "label": "Largeur du bouton", "min": 14, "max": 44, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "padding_top", "label": "Espace au-dessus", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 112 },
    { "type": "range", "id": "padding_bottom", "label": "Espace en dessous", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 88 },

    { "type": "header", "content": "Polices" },
    { "type": "checkbox", "id": "use_custom_fonts", "label": "Charger Host Grotesk + Playfair Display", "info": "Décochez pour utiliser la police de votre thème", "default": true }
  ],
  "presets": [
    { "name": "Appel à l'action final" }
  ]
}
{% endschema %}